# =============================================================================
# Context-Aware Sequential Add-On Recommendation System
# Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Project Settings
# -----------------------------------------------------------------------------
PROJECT_NAME=addon-recommendation
ENVIRONMENT=development  # development, staging, production
DEBUG=true

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
DATA_DIR=./data
CHECKPOINT_DIR=./checkpoints
LOG_DIR=./logs
OUTPUT_DIR=./outputs

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/addon_rec
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# ML Experiment Tracking
# -----------------------------------------------------------------------------
WANDB_API_KEY=your-wandb-api-key
WANDB_PROJECT=addon-recommendation
WANDB_ENTITY=your-wandb-entity

# MLflow (alternative)
MLFLOW_TRACKING_URI=http://localhost:5000

# -----------------------------------------------------------------------------
# Cloud Storage (optional)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# GCP (alternative)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET=your-gcs-bucket

# -----------------------------------------------------------------------------
# GPU Configuration
# -----------------------------------------------------------------------------
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
NUMEXPR_NUM_THREADS=8

# -----------------------------------------------------------------------------
# Feature Store (optional)
# -----------------------------------------------------------------------------
FEAST_REPO_PATH=./feature_repo
FEATURE_STORE_ONLINE_HOST=localhost
FEATURE_STORE_ONLINE_PORT=6566

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret
ENCRYPTION_KEY=your-encryption-key
